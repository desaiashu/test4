sig
  bpm 130
  system 12tet western
  scale C chromatic

arr
  main 32 |bfw

tracks
  1 audio |kgr
    type audio
    strip tivraStrip
  2 midi |btf
    type midi
    plugin tivra4OSC
    fx Abbey Road RS127 Box
    fx2 tivraModularFx
    strip tivraStrip
  3 MIDI |qgr
    type midi
    strip tivraStrip
  4 Audio |xhb
    type audio
    strip tivraStrip
  5 MIDI |jwz
    type midi
    strip tivraStrip
  6 MIDI |ldo
    type midi
    strip tivraStrip
  7 MIDI |ous
    type midi
    strip tivraStrip
  8 MIDI |aoq
    type midi
    strip tivraStrip
  9 MIDI |tfr
    type midi
    strip tivraStrip
  10 Audio |qxc
    type audio
    strip tivraStrip
  11 MIDI |xbm
    type midi
    strip tivraStrip
  12 Audio |fvo
    type audio
    strip tivraStrip
  13 MIDI |szl
    type midi
    strip tivraStrip
  14 Audio |slc
    type audio
    strip tivraStrip
  15 MIDI |yju
    type midi
    strip tivraStrip
  16 Audio |czc
    type audio
    strip tivraStrip
  17 MIDI |cek
    type midi
    strip tivraStrip

returns
  0 Hall |rdi
    fx tivraHall
    strip tivraStrip
  1 Plate |rhd
    fx tivraPlate
    strip tivraStrip
  2 Delay |rjs
    fx tivraDelay
    strip tivraStrip
  3 Color |rih
    fx tivraDistortion
    strip tivraStrip

sec main
  trk 1 audio |kgr
    c 4:165 34:256 |mepv
      'samples/Chicago sketch 10-Mini V3.wav'
  trk 2 midi |btf
    c 0:0 16:96 |ujpm
      p _q xx _qd xx _q xx _qd xx _h _xx xx _xx xx _xx xx _w11 q q q q q q q q q
        v 100 100 100 100 100 100 100 90 90 90 90 90 90 90 90 90
        n E3 A3 E3 G#3 F#3 B3 F#3 C4 D4 E3 A#3 G#3 F#3 G3 A3 F3
      p _w14 q q q q q q q q q
        v 90
        n E4 F#4 G#3 D4 C4 A#3 B3 C#4 A3
        .
        v 90
        n G4 A4 B3 F4 D#4 C#4 D4 E4 C4
    c 14:0 12:0 |ssck
      p w _w3 w _w w _w w _w w _w
        v .
        n C3 C4 C4 C3 G3
      p w _w7 w _w3
        v .
        n D#3
  trk 3 MIDI |qgr
    c 8:0 8:0 |oqiy
  trk 17 MIDI |cek
    c 8:0 8:0 |ohqo
