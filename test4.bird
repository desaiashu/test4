sig
  bpm 130
  system 12tet western
  scale C chromatic

arr
  main 32 |bfw

tracks
  1 audio |kgr
    type audio
    strip tivraStrip
  2 midi |btf
    type midi
    plugin tivra4OSC
    fx Abbey Road RS127 Box
    strip tivraStrip

returns
  0 Hall |rdi
    fx tivraHall
    strip tivraStrip
  1 Plate |rhd
    fx tivraPlate
    strip tivraStrip
  2 Delay |rjs
    fx tivraDelay
    strip tivraStrip
  3 Color |rih
    fx tivraDistortion
    strip tivraStrip

sec main
  trk 1 audio |kgr
    c 4:165 34:256 |mepv
      'samples/Chicago sketch 10-Mini V3.wav'
  trk 2 midi |btf
    c 0:0 14:96 |ujpm
      p _q xx _qd xx _q xx _qd xx _h _xx xx _xx xx _xx xx _w11 q
        v 100 100 100 100 100 100 100 90
        n E3 A3 E3 G#3 F#3 B3 F#3 C4
      p _w14 q
        v 90
        n E4
        .
        v 90
        n G4
    c 14:0 12:0 |ssck
      p w _w
        v .
        n C3 G3 F3 C4 C3 G3
      p w _w3
        v .
        n D#3 G#3 D#3
        .
        v .
        n G3 C4 G3
